# =============================================================================
# Partilhou — variaveis de ambiente (copie para .env.local e preencha)
# =============================================================================
# IMPORTANTE: chaves com prefixo NEXT_PUBLIC_ vao para o browser. NUNCA coloque
# segredos (service_role, tokens do gateway) atras de NEXT_PUBLIC_.
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Encontradas em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...publishable-or-anon...
# SECRETO — apenas no servidor. Faz bypass de RLS. NUNCA exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=ey...service-role...

# --- Mercado Pago ------------------------------------------------------------
# Painel de desenvolvedor: https://www.mercadopago.com.br/developers
# SECRETO — apenas servidor.
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# Chave secreta da assinatura de webhook (Webhooks > configurar > assinatura)
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-signing-secret
# Public key (pode ir ao cliente se usar Checkout Bricks)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-public-...

# --- Pagamentos / Escrow -----------------------------------------------------
# Provider ativo: "mercadopago" | "mock"
PAYMENT_PROVIDER=mock

# --- Seguranca ---------------------------------------------------------------
# Segredo usado para HMAC de codigos de afiliado e hashing de IP (clicks).
AFFILIATE_HASH_SECRET=troque-por-uma-string-aleatoria-longa
